---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Documentos">
  <section class="section">
    <div class="container">
      <h1>Documentos</h1>
      <p style="color:var(--text-secondary); max-width:600px;">
        Estatutos, libros de abstracts de congresos anteriores y otros documentos de la Sociedad.
      </p>
      <div class="card" style="max-width:520px;">
        <p>Todos los documentos se alojan en un repositorio externo para mantener el sitio ligero.</p>
        <a class="btn" href="https://drive.google.com/REEMPLAZAR-CON-ENLACE-REAL" target="_blank">Ir al repositorio de documentos</a>
      </div>

      <div class="card" style="max-width:520px; margin-top:12px;">
        <h3 style="margin-top:0;">Documentos disponibles en el sitio anterior</h3>
        <p style="color:var(--text-secondary); font-size:14px; margin-bottom:8px;">
          Pendientes de subir al repositorio externo de arriba:
        </p>
        <ul style="color:var(--text-secondary); font-size:14px; padding-left:1.2rem; margin:0;">
          <li>Estatutos de SOMIAMA</li>
          <li>Libro de Abstracts — XXX Reunión SOMIAMA 2025</li>
          <li>Libro de Abstracts — XXIX Reunión SOMIAMA 2024</li>
          <li>Libro de Abstracts — SOMIAMA 2023</li>
          <li>Libro de Abstracts — SOMIAMA 2022</li>
          <li>Libro de Abstracts — SOMIAMA 2021</li>
          <li>Libro de Abstracts — SOMIAMA 2020</li>
          <li>Libro de Abstracts — XXIV Reunión SOMIAMA 2019</li>
          <li>Libro de Abstracts — SOMIAMA 2018</li>
        </ul>
      </div>
      <div class="card" id="covid19" style="max-width:520px; margin-top:12px;">
        <h3>Protocolo COVID-19</h3>
        <p>Documento de consulta.</p>
        <a class="btn-outline" href="/documentos/protocolo-covid19.pdf" target="_blank">Descargar PDF</a>
      </div>
    </div>
  </section>
</BaseLayout>
