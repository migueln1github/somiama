---
import BaseLayout from '../layouts/BaseLayout.astro';

const ofertasModules = import.meta.glob('../data/ofertas-items/*.json', { eager: true });
const ofertas = Object.values(ofertasModules).map((m) => m.default);
const ordenadas = [...ofertas].sort((a, b) => new Date(b.fecha) - new Date(a.fecha));
---
<BaseLayout title="Ofertas de trabajo">
  <section class="section">
    <div class="container">
      <h1>Ofertas de trabajo</h1>
      <div style="display:flex; flex-direction:column; gap:12px; margin-top:1rem;">
        {ordenadas.map(o => (
          <div class="card">
            <h3 style="margin:0 0 4px;">{o.puesto}</h3>
            <p style="margin:0 0 4px; color:var(--text-secondary);">{o.institucion}</p>
            <p style="margin:0 0 8px;">{o.descripcion}</p>
            <a href={`mailto:${o.contacto}`} style="font-size:0.85rem;">{o.contacto}</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
