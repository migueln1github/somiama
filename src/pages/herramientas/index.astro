---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { id: 'apache2', name: 'APACHE II', desc: 'Score de gravedad y mortalidad estimada.', href: '/herramientas/apache2' },
  { id: 'sofa', name: 'SOFA', desc: 'Evaluación secuencial de fallo orgánico.', href: '/herramientas/sofa' },
  { id: 'saps2', name: 'SAPS II', desc: 'Score simplificado de fisiología aguda.', href: '/herramientas/saps2' },
  { id: 'saps3', name: 'SAPS III', desc: 'Versión actualizada del SAPS.', href: '/herramientas/saps3' },
];
---
<BaseLayout title="Herramientas clínicas">
  <section class="section">
    <div class="container">
      <h1>Herramientas clínicas</h1>
      <p style="color:var(--text-secondary); max-width:600px;">Calculadoras de uso habitual en Cuidados Intensivos.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px; margin-top:1.5rem;">
        {tools.map(t => (
          <a href={t.href} id={t.id} class="card" style="text-decoration:none; color:inherit;">
            <h3>{t.name}</h3>
            <p style="color:var(--text-secondary); margin:0;">{t.desc}</p>
          </a>
        ))}
        <a href="/documentos#covid19" class="card" style="text-decoration:none; color:inherit;">
          <h3>Protocolo COVID-19</h3>
          <p style="color:var(--text-secondary); margin:0;">Documento de consulta (PDF).</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
