---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sociedad">
  <section class="section">
    <div class="container">
      <h1>Quiénes somos</h1>
      <p style="max-width:640px; color:var(--text-secondary);">
        SOMIAMA es una sociedad científica que busca potenciar el desarrollo de la Medicina Intensiva
        en todos sus aspectos: asistenciales, de investigación y de formación.
      </p>
      <h2 style="margin-top:2rem;">Junta Directiva</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:14px; margin-top:1rem;">
        <div class="card">
          <strong>Dr. Félix Maimir Jané</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Presidente</p>
          <a href="mailto:presidente@somiama.org">presidente@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dr. Manuel Quintana Díaz</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Vicepresidente</p>
          <a href="mailto:vicepresidente@somiama.org">vicepresidente@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dra. Paloma Sánchez Mata</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Tesorera</p>
          <a href="mailto:tesorero@somiama.org">tesorero@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dra. Judit Iglesias Franco</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Vocal</p>
          <a href="mailto:vocal@somiama.org">vocal@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dr. Javier Nieto García</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Secretaría · Vocal de Residentes</p>
          <a href="mailto:secretario@somiama.org">secretario@somiama.org</a> ·
          <a href="mailto:residentes@somiama.org">residentes@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dña. Rocío González Blanco</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Vocal de Enfermería</p>
          <a href="mailto:enfermeria@somiama.org">enfermeria@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dr. César Pérez-Caballero Macarrón</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Vocal de Intensivos Pediátricos</p>
          <a href="mailto:pediatria@somiama.org">pediatria@somiama.org</a>
        </div>
        <div class="card">
          <strong>Dr. Miguel Ángel González Gallego</strong>
          <p style="color:var(--text-secondary); margin:2px 0 6px;">Vocal de Servicios Digitales</p>
          <a href="mailto:webmaster@somiama.org">webmaster@somiama.org</a>
        </div>
      </div>

      <h2 style="margin-top:2.5rem;">Nuestros fines</h2>
      <p style="max-width:640px; color:var(--text-secondary);">
        Así mismo, SOMIAMA busca defender los intereses profesionales de sus miembros y
        representarles ante las personas o entidades públicas o privadas, asesorándoles sobre
        aspectos sociales, profesionales, deontológicos y en todos aquellos que se deriven del
        ejercicio de la Medicina Intensiva.
      </p>
    </div>
  </section>
</BaseLayout>
