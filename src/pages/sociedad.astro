---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sociedad">
  <section class="section">
    <div class="container">
      <h1>Quiénes somos</h1>
      <p style="max-width:640px; color:var(--text-secondary);">
        SOMIAMA es una sociedad científica que busca potenciar el desarrollo de la Medicina Intensiva
        en todos sus aspectos: asistenciales, de investigación y de formación.
      </p>
      <h2 style="margin-top:2rem;">Junta Directiva</h2>
      <p style="color:var(--text-secondary);">Completar con los cargos actuales de la Junta.</p>
    </div>
  </section>
</BaseLayout>
