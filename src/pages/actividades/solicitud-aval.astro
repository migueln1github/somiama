---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Solicitud de aval científico">
  <section class="section">
    <div class="container">
      <h1>Solicitud de aval científico</h1>
      <p style="max-width:600px; color:var(--text-secondary);">
        SOMIAMA avala actividades científicas de todo tipo (cursos, reuniones, publicaciones...)
        siempre que reúnan determinados requisitos de calidad y sean de interés para sus
        asociados y la comunidad científica en general. Rellena el siguiente formulario y nos
        pondremos en contacto contigo con las condiciones y la documentación necesaria.
      </p>
      <div class="card" style="max-width:520px;">
        <form name="solicitud-aval" method="POST" action="/gracias" data-netlify="true" data-netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="solicitud-aval" />
          <p style="display:none;"><label>No rellenar: <input name="bot-field" /></label></p>

          <label>Nombre y apellidos del solicitante<br/><input type="text" name="nombre" required style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Email<br/><input type="email" name="email" required style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Entidad organizadora<br/><input type="text" name="entidad" required style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Nombre de la actividad<br/><input type="text" name="actividad" required style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Fecha prevista<br/><input type="date" name="fecha" style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Breve descripción<br/><textarea name="descripcion" rows="4" required style="width:100%; padding:8px; margin:4px 0 12px;"></textarea></label>
          <button type="submit" class="btn">Enviar solicitud</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
