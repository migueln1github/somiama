---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Actividades">
  <section class="section">
    <div class="container">
      <h1>Actividades</h1>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px; margin-top:1rem;">
        <div class="card"><h3>Reunión Anual / Congresos</h3><p style="color:var(--text-secondary);">Completar con el contenido actual.</p></div>
        <div class="card"><h3>Cursos</h3><p style="color:var(--text-secondary);">Completar con el contenido actual.</p></div>
        <div class="card"><h3>Actividades Avaladas</h3><p style="color:var(--text-secondary);">Incluye el formulario de solicitud de aval.</p></div>
      </div>
    </div>
  </section>
</BaseLayout>
