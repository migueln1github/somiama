---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto">
  <section class="section">
    <div class="container">
      <h1>Contacto</h1>
      <div class="card" style="max-width:480px;">
        <form name="contacto" method="POST" action="/gracias" data-netlify="true" data-netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contacto" />
          <p style="display:none;"><label>No rellenar: <input name="bot-field" /></label></p>

          <label>Nombre<br/><input type="text" name="nombre" required style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Email<br/><input type="email" name="email" required style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Mensaje<br/><textarea name="mensaje" rows="4" required style="width:100%; padding:8px; margin:4px 0 12px;"></textarea></label>
          <button type="submit" class="btn">Enviar</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
