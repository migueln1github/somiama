---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto">
  <section class="section">
    <div class="container">
      <h1>Contacto</h1>
      <div class="card" style="max-width:480px;">
        <form>
          <label>Nombre<br/><input type="text" name="nombre" style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Email<br/><input type="email" name="email" style="width:100%; padding:8px; margin:4px 0 12px;" /></label>
          <label>Mensaje<br/><textarea name="mensaje" rows="4" style="width:100%; padding:8px; margin:4px 0 12px;"></textarea></label>
          <button type="submit" class="btn">Enviar</button>
        </form>
        <p style="font-size:0.8rem; color:var(--text-secondary); margin-top:12px;">
          Pendiente de conectar a un backend de formularios (ver README).
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
