---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Área de socios">
  <section class="section">
    <div class="container" style="max-width: 640px;">
      <h1>Área de socios</h1>
      <p style="color:var(--text-secondary); margin-bottom:1.5rem;">
        Inicia sesión para acceder al material restringido y gestionar tus datos.
      </p>

      <div id="clerk-loading" style="color:var(--text-secondary); font-size:14px;">
        Cargando…
      </div>

      <div id="clerk-signed-out" style="display:none;">
        <a id="sign-in-link" class="btn" href="#">Iniciar sesión</a>
      </div>

      <div id="clerk-signed-in" style="display:none;">
        <div class="card" style="margin-bottom:1.5rem;">
          <h2 style="margin-top:0; font-size:16px;">Material restringido a socios</h2>
          <ul style="color:var(--text-secondary); padding-left:1.2rem; margin:0;">
            <li>Actas de la Junta Directiva</li>
            <li>Convocatorias de la Reunión Anual</li>
            <li>Descuentos en congresos y cursos avalados</li>
          </ul>
          <p style="font-size:13px; color:var(--text-secondary); margin-top:0.75rem;">
            (Contenido de ejemplo — pendiente de sustituir por los enlaces/documentos reales)
          </p>
        </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a id="manage-account-link" class="btn" href="#">Gestionar mi cuenta (perfil / contraseña)</a>
          <button id="sign-out-btn" class="btn" style="background:transparent; border:1px solid var(--border);">Cerrar sesión</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { Clerk } from '@clerk/clerk-js';

  const publishableKey = import.meta.env.PUBLIC_CLERK_PUBLISHABLE_KEY;

  const loadingEl = document.getElementById('clerk-loading')!;
  const signedOutEl = document.getElementById('clerk-signed-out')!;
  const signedInEl = document.getElementById('clerk-signed-in')!;

  function showError(msg: string) {
    loadingEl.textContent = msg;
    loadingEl.style.color = '#b3403a';
  }

  if (!publishableKey) {
    showError('Falta configurar PUBLIC_CLERK_PUBLISHABLE_KEY (ver README, sección Área de socios / Clerk).');
  } else {
    try {
      // El dominio propio de tu app de Clerk va codificado dentro de la propia clave pública.
      // OJO: ese dominio es el de la API de Clerk (termina en ".clerk.accounts.dev"),
      // pero las páginas de login/perfil alojadas (Account Portal) viven en el mismo
      // nombre SIN ese ".clerk." en medio — hay que quitarlo.
      const apiDomain = atob(publishableKey.split('_')[2]).slice(0, -1);
      const accountPortalDomain = apiDomain.replace('.clerk.accounts.dev', '.accounts.dev');
      const currentUrl = window.location.href;

      // Cargamos Clerk en modo "headless": solo para saber si hay sesión iniciada,
      // sin intentar montar ningún formulario nuestro (eso es lo que fallaba antes).
      const clerk = new Clerk(publishableKey);
      await clerk.load();

      loadingEl.style.display = 'none';

      if (clerk.user) {
        signedInEl.style.display = 'block';
        (document.getElementById('manage-account-link') as HTMLAnchorElement).href =
          `https://${accountPortalDomain}/user?redirect_url=${encodeURIComponent(currentUrl)}`;
        document.getElementById('sign-out-btn')!.addEventListener('click', async () => {
          await clerk.signOut();
          window.location.reload();
        });
      } else {
        signedOutEl.style.display = 'block';
        (document.getElementById('sign-in-link') as HTMLAnchorElement).href =
          `https://${accountPortalDomain}/sign-in?redirect_url=${encodeURIComponent(currentUrl)}`;
      }
    } catch (err) {
      showError('Error cargando Clerk: ' + (err instanceof Error ? err.message : String(err)));
      console.error(err);
    }
  }
</script>
