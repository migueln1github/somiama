---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Hazte socio">
  <section class="section">
    <div class="container">
      <h1>Hazte socio de SOMIAMA</h1>
      <p style="max-width:600px; color:var(--text-secondary);">
        Si eres profesional de la Medicina Intensiva, únete a la Sociedad.
      </p>
      <div class="card" style="max-width:480px;">
        <p>Formulario de alta de socio — pendiente de conectar con el backend de formularios.</p>
        <a class="btn" href="/contacto">Solicitar información</a>
      </div>
    </div>
  </section>
</BaseLayout>
