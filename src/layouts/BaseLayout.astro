---
import '../styles/global.css';

const { title, description = 'Sociedad de Medicina Intensiva de Madrid' } = Astro.props;

const nav = [
  { href: '/sociedad', label: 'Sociedad' },
  { href: '/hazte-socio', label: 'Hazte socio' },
  { href: '/actividades', label: 'Actividades' },
  { href: 'https://formacion.somiama.org', label: 'Formación', external: true },
  { href: '/herramientas', label: 'Herramientas clínicas' },
  { href: '/ofertas-trabajo', label: 'Ofertas de trabajo' },
  { href: '/mapa', label: 'Mapa de servicios' },
  { href: '/documentos', label: 'Documentos' },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · SOMIAMA</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" />
</head>
<body>
  <header style="background:var(--navy);">
    <div class="container" style="display:flex; align-items:center; justify-content:space-between; padding:14px 24px; flex-wrap:wrap; gap:10px;">
      <a href="/" style="color:#fff; font-family:var(--font-display); font-weight:900; font-size:1.1rem; text-decoration:none; letter-spacing:0.5px;">SOMIAMA</a>
      <nav style="display:flex; gap:16px; flex-wrap:wrap;">
        {nav.map(item => (
          <a href={item.href} target={item.external ? '_blank' : undefined}
             style="color:#cdd8e2; font-size:0.85rem; text-decoration:none;">{item.label}</a>
        ))}
        <a href="/area-socios" style="color:#fff; font-size:0.85rem; text-decoration:none; border-bottom:2px solid var(--teal); padding-bottom:2px;">Área socios</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer style="border-top:1px solid var(--border); margin-top:3rem; padding:2rem 0; background:var(--surface);">
    <div class="container" style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:16px; font-size:0.85rem; color:var(--text-secondary);">
      <div>© {new Date().getFullYear()} SOMIAMA — Sociedad de Medicina Intensiva de Madrid</div>
      <div style="display:flex; gap:16px;">
        <a href="/contacto" style="color:var(--text-secondary);">Contacto</a>
        <a href="/aviso-legal" style="color:var(--text-secondary);">Aviso legal y privacidad</a>
      </div>
    </div>
  </footer>
</body>
</html>
